{
  "name": "@pulsyflux/nodejs-broker",
  "version": "1.0.0",
  "description": "Node.js bindings for PulsyFlux - high-performance pub/sub message broker with native C++ addon and Go shared library",
  "main": ".bin/release/registry.mjs",
  "type": "module",
  "exports": {
    ".": {
      "import": "./.bin/release/registry.mjs",
      "types": "./types/index.d.ts"
    }
  },
  "scripts": {
    "preinstall": "pnpm dlx only-allow pnpm",
    "postinstall": "node postinstall.mjs"
  },
  "files": [
    "addon.cc",
    "build.mjs",
    "registry.mjs",
    "postinstall.mjs",
    "types/",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "node-addon-api": "8.5.0",
    "node-api-headers": "1.3.0",
    "zig-build": "github:solarwinds/zig-build#main"
  },
  "devDependencies": {
    "jasmine": "5.13.0",
    "tsx": "4.21.0"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "pnpm@10.11.0",
  "os": [
    "win32"
  ],
  "cpu": [
    "x64"
  ],
  "keywords": [
    "pulsyflux",
    "pubsub",
    "pub-sub",
    "message-broker",
    "broker",
    "messaging",
    "events",
    "tcp",
    "multiplexing",
    "high-performance",
    "native-addon",
    "golang",
    "c++",
    "real-time"
  ],
  "author": {
    "name": "PulsyFlux Team"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/pulsyflux/nodejs-broker.git"
  },
  "homepage": "https://github.com/pulsyflux/nodejs-broker#readme",
  "bugs": {
    "url": "https://github.com/pulsyflux/nodejs-broker/issues"
  }
}